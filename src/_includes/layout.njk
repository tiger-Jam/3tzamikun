<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{% if title %}{{ title }} - {% endif %}{{ site.title }}</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<table class="frame" cellspacing="0" cellpadding="0" border="0">
<tr>
<td class="header" colspan="2">
<h1><a href="/">{{ site.title }}</a></h1>
<div class="tagline">{{ site.tagline }}</div>
<div class="nav">
[ <a href="/">TOP</a> | <a href="/tools/">TOOLS</a> | <a href="/blog/">BLOG</a> | <a href="/contact/">CONTACT</a> ]
</div>
</td>
</tr>
<tr>
<td class="main">
{{ content | safe }}
</td>
<td class="side">
<div class="box">
<div class="box-title">MENU</div>
<ul>
<li><a href="/">TOP</a></li>
<li><a href="/tools/">TOOLS</a></li>
<li><a href="/blog/">BLOG</a></li>
<li><a href="/contact/">CONTACT</a></li>
</ul>
</div>

<div class="box">
<div class="box-title">TOOLS</div>
<ul>
{% for t in collections.tools %}
<li><a href="{{ t.data.link or t.url }}">{{ t.data.title }}</a></li>
{% else %}
<li>(準備中)</li>
{% endfor %}
</ul>
</div>

<div class="box">
<div class="box-title">RECENT</div>
<ul>
{% for p in collections.posts | take(5) %}
<li><a href="{{ p.url }}">{{ p.data.title }}</a></li>
{% else %}
<li>(まだ投稿なし)</li>
{% endfor %}
</ul>
</div>
</td>
</tr>
<tr>
<td class="footer" colspan="2">
&copy; {{ site.since }} {{ site.author }} - powered by hand-coded HTML
</td>
</tr>
</table>

</body>
</html>
